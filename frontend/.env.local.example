# ═══════════════════════════════════════════════════════════════
# LAUNCHLENS FRONTEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# BACKEND API (Development: local, Production: deployed URL)
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# SUPABASE AUTHENTICATION (Required for user accounts)
# Get from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_KEY=YOUR_ANON_KEY_HERE
# Use the ANON key (not SERVICE_ROLE key)

# ENVIRONMENT
VITE_ENVIRONMENT=development
# Options: development, production, staging

# APP INFO
VITE_APP_NAME=LaunchLens
VITE_APP_VERSION=1.0.0

# OPTIONAL: Analytics & Error Tracking
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
VITE_SESSION_TIMEOUT=3600000  # 1 hour in milliseconds
